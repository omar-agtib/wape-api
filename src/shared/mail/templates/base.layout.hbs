<html lang='fr'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{subject}}</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f4f6f9;
        color: #1a1a2e;
      }
      .wrapper {
        max-width: 620px;
        margin: 40px auto;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }
      .header {
        background: #1a1a2e;
        padding: 28px 40px;
        text-align: center;
      }
      .header .logo {
        font-size: 26px;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 3px;
      }
      .header .logo span {
        color: #4f8ef7;
      }
      .header .tagline {
        color: #8892a4;
        font-size: 12px;
        margin-top: 4px;
        letter-spacing: 1px;
        text-transform: uppercase;
      }
      .body {
        padding: 40px;
      }
      .body h1 {
        font-size: 22px;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 16px;
      }
      .body p {
        font-size: 15px;
        line-height: 1.7;
        color: #4a5568;
        margin-bottom: 16px;
      }
      .body .highlight {
        background: #f0f6ff;
        border-left: 4px solid #4f8ef7;
        border-radius: 0 8px 8px 0;
        padding: 16px 20px;
        margin: 24px 0;
      }
      .body .highlight p {
        margin: 0;
        color: #1a1a2e;
      }
      .body .btn {
        display: inline-block;
        background: #4f8ef7;
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 32px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        margin: 24px 0;
      }
      .body .btn-danger {
        background: #e53e3e;
      }
      .body .btn-warning {
        background: #dd6b20;
      }
      .table-wrap {
        background: #f8fafc;
        border-radius: 8px;
        padding: 20px;
        margin: 20px 0;
      }
      .table-wrap table {
        width: 100%;
        border-collapse: collapse;
      }
      .table-wrap td {
        padding: 8px 12px;
        font-size: 14px;
        border-bottom: 1px solid #e2e8f0;
      }
      .table-wrap td:first-child {
        color: #718096;
        font-weight: 500;
        width: 45%;
      }
      .table-wrap td:last-child {
        color: #1a1a2e;
        font-weight: 600;
      }
      .table-wrap tr:last-child td {
        border-bottom: none;
      }
      .badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
      }
      .badge-success {
        background: #c6f6d5;
        color: #276749;
      }
      .badge-warning {
        background: #fefcbf;
        color: #975a16;
      }
      .badge-danger {
        background: #fed7d7;
        color: #9b2c2c;
      }
      .badge-info {
        background: #bee3f8;
        color: #2a69ac;
      }
      .footer {
        background: #f8fafc;
        padding: 24px 40px;
        text-align: center;
        border-top: 1px solid #e2e8f0;
      }
      .footer p {
        font-size: 12px;
        color: #a0aec0;
        line-height: 1.6;
      }
      .footer a {
        color: #4f8ef7;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='header'>
        <div class='logo'>W<span>A</span>PE</div>
        <div class='tagline'>Work & Assets Project ERP</div>
      </div>
      <div class='body'>
        {{{body}}}
      </div>
      <div class='footer'>
        <p>
          Cet email a été envoyé par
          <strong>WAPE Platform</strong>
          — ERP Construction & Ingénierie.<br />
          <a href='{{frontendUrl}}'>Accéder à la plateforme</a>
          &nbsp;·&nbsp;
          <a href='{{frontendUrl}}/support'>Support</a>
          &nbsp;·&nbsp;
          <a href='{{frontendUrl}}/settings'>Paramètres</a>
        </p>
        <p style='margin-top: 12px;'>© {{year}} WAPE. Tous droits réservés.</p>
      </div>
    </div>
  </body>
</html>